<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<SplitPane dividerPositions="0.4" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.gestion.controllers.BuscarVacantesController" prefHeight="700" style="-fx-padding: 10;">
    <items>
        <VBox spacing="12" style="-fx-padding: 5;">
            <Label text="Bolsa de Empleo - Ofertas Disponibles" style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 12pt;"/>

            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 4px;">
                <TextField fx:id="txtBuscarOfertas" promptText="🔍 Filtrar por puesto, empresa o tecnología..." HBox.hgrow="ALWAYS"/>
            </HBox>

            <TableView fx:id="tblOfertasBolsa" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colTitulo" text="Titulo de oferta" prefWidth="180"/>
                    <TableColumn fx:id="colPuesto" text="Puesto / Vacante" prefWidth="180"/>
                    <TableColumn fx:id="colEmpresa" text="Empresa" prefWidth="140"/>
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="15" style="-fx-padding: 10;">
            <Label text="Expediente Técnico de la Convocatoria" style="-fx-font-size: 13pt; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>

            <VBox fx:id="panelDetalleOferta" spacing="15" VBox.vgrow="ALWAYS" styleClass="card-dashboard" style="-fx-padding: 15; -fx-background-color: #f8fafc; -fx-border-left-color: #2563eb; -fx-border-left-width: 5px; -fx-border-radius: 4px;">

                <VBox spacing="4">
                    <Label fx:id="lblTituloPuesto" text="Seleccione una oferta de la lista" style="-fx-font-size: 14pt; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;" wrapText="true"/>
                    <Label fx:id="lblNombreEmpresa" text="Para visualizar los requisitos y detalles" style="-fx-font-size: 11pt; -fx-text-fill: #475569; -fx-font-style: italic;"/>
                </VBox>

                <Separator/>

                <GridPane vgap="8" hgap="15">
                    <columnConstraints>
                        <ColumnConstraints prefWidth="120"/>
                        <ColumnConstraints prefWidth="300"/>
                    </columnConstraints>
                    <children>
                        <Label text="⏱️ Duración:" style="-fx-text-fill: #64748b;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDuracionHoras" text="-- Horas" style="-fx-font-weight: bold; -fx-text-fill: #334155;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="👥 Vacantes Libres:" style="-fx-text-fill: #64748b;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="lblVacantesDisponibles" text="-- cupos" style="-fx-font-weight: bold; -fx-text-fill: #334155;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="📍 Ubicación Sede:" style="-fx-text-fill: #64748b;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblUbicacionEmpresa" text="--" style="-fx-text-fill: #334155;" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </children>
                </GridPane>

                <Separator/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <VBox spacing="12">
                            <children>
                                <VBox spacing="4">
                                    <Label text="Descripción General del Puesto:" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                                    <Label fx:id="lblDescripcionPuesto" wrapText="true" style="-fx-text-fill: #64748b;" text="--"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Requisitos y Conocimientos Técnicos:" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                                    <Label fx:id="lblRequisitosPuesto" wrapText="true" style="-fx-text-fill: #64748b;" text="--"/>
                                </VBox>
                                <VBox spacing="4">
                                    <Label text="Actividades Obligatorias a Desarrollar:" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                                    <Label fx:id="lblActividadesPuesto" wrapText="true" style="-fx-text-fill: #64748b;" text="--"/>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <Separator/>

                <VBox spacing="6">
                    <Label text="Documento de Convocatoria Oficial (PDF firmado):" style="-fx-font-size: 9pt; -fx-text-fill: #64748b;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="btnRevisarOfertaPDF" text="👁 Revisar Convocatoria PDF" onAction="#handleRevisarPDF" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button fx:id="btnDescargarOfertaPDF" text="📥 Descargar PDF" onAction="#handleDescargarPDF" style="-fx-background-color: #475569; -fx-text-fill: white;"/>
                    </HBox>
                </VBox>
            </VBox>

            <HBox spacing="15" alignment="CENTER_RIGHT">
                <Label fx:id="lblEstado" visible="false" wrapText="true" style="-fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnPostularBolsa" text="Confirmar y Postular a Vacante" onAction="#handlePostular" styleClass="button-primary" prefHeight="35"/>
            </HBox>
        </VBox>
    </items>
</SplitPane>