<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.gestion.controllers.TutorAcademicoMainController" prefWidth="1280.0" prefHeight="850.0" stylesheets="@../../css/styles.css">
    <top>
        <!-- Contenedor vertical para organizar simétricamente la MenuBar y la ToolBar del Tutor Académico -->
        <VBox>
            <children>
                <!-- 1. BARRA DE MENÚS (MenuBar): Tu árbol de navegación desplegable original -->
                <MenuBar>
                    <Menu text="Inicio">
                        <MenuItem text="Alumnos Tutorados" onAction="#handleAlumnosTutorados"/>
                    </Menu>
                    <Menu text="Validaciones">
                        <MenuItem text="Validar Actividades" onAction="#handleValidarActividades"/>
                        <MenuItem text="Firmar Formulario 1" onAction="#handleFirmarFormulario1"/>
                    </Menu>
                    <Menu text="Formatos Finales">
                        <MenuItem text="Revisar Formulario 2" onAction="#handleRevisarFormulario2"/>
                        <MenuItem text="Emitir Formulario 3" onAction="#handleEmitirFormulario3"/>
                    </Menu>
                    <Menu text="Sesión">
                        <MenuItem text="Cerrar Sesión" onAction="#handleCerrarSesion"/>
                        <MenuItem text="Salir del Sistema" onAction="#handleSalirSistema"/>
                    </Menu>
                    <Menu text="Ayuda">
                        <MenuItem text="Acerca del programa" onAction="#handleAcercaPrograma"/>
                        <MenuItem text="Acerca del desarrollador" onAction="#handleAcercaDesarrollador"/>
                        <MenuItem text="Repositorio GitHub" onAction="#handleRepositorioGitHub"/>
                    </Menu>
                </MenuBar>

                <!-- 2. BARRA DE HERRAMIENTAS (ToolBar): Botones expuestos para la ejecución de acciones rápidas -->
                <ToolBar>
                    <items>
                        <!-- Bloque de Inicio y Control Operativo -->
                        <Button text="👨‍🎓 Alumnos Tutorados" onAction="#handleAlumnosTutorados"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Bloque de Validaciones y Fase Inicial -->
                        <Button text="📝 Validar Actividades" onAction="#handleValidarActividades"/>
                        <Button text="📜 Firmar Formulario 1" onAction="#handleFirmarFormulario1"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Bloque de Formatos Finales y Cierre -->
                        <Button text="👁 Revisar Formulario 2" onAction="#handleRevisarFormulario2"/>
                        <Button text="📤 Emitir Formulario 3" onAction="#handleEmitirFormulario3"/>

                        <!-- Región invisible de expansión que empuja el botón de salida al extremo derecho -->
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Botón directo de salida con el estilo de peligro unificado -->
                        <Button text="🚪 Cerrar Sesión" onAction="#handleCerrarSesion" styleClass="button-danger"/>
                    </items>
                </ToolBar>
            </children>
        </VBox>
    </top>
    <center>
        <!-- Panel de Visualización Central Único encargado de reemplazar el contenido -->
        <StackPane fx:id="panelCentralDisp" style="-fx-padding: 20;"/>
    </center>
</BorderPane>