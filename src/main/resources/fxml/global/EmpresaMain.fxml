<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" prefWidth="1280.0" prefHeight="850.0" stylesheets="@../../css/styles.css" fx:controller="com.ucuenca.gestion.controllers.EmpresaMainController">
    <top>
        <!-- Contenedor vertical para apilar de forma limpia la MenuBar y la ToolBar corporativa -->
        <VBox>
            <children>
                <!-- 1. BARRA DE MENÚS (MenuBar): Mantiene intactas tus opciones de navegación desplegables originales -->
                <MenuBar>
                    <Menu text="Inicio">
                        <MenuItem text="Cuadro de Mando" onAction="#handleCuadroMando"/>
                    </Menu>
                    <Menu text="Convocatorias">
                        <MenuItem text="Crear Oferta" onAction="#handleCrearOferta"/>
                        <MenuItem text="Historial de Ofertas" onAction="#handleHistorialOfertas"/>
                        <MenuItem text="Gestión de Candidatos" onAction="#handleGestionCandidatos"/>
                    </Menu>
                    <Menu text="Convenio">
                        <MenuItem text="Tramitar Convenio" onAction="#handleTramitarConvenio"/>
                    </Menu>
                    <Menu text="Sesión">
                        <MenuItem text="Cerrar Sesión" onAction="#handleCerrarSesion"/>
                        <MenuItem text="Salir del Sistema" onAction="#handleSalirSistema"/>
                    </Menu>
                    <Menu text="Ayuda">
                        <MenuItem text="Acerca del programa" onAction="#handleAcercaPrograma"/>
                        <MenuItem text="Acerca del desarrollador" onAction="#handleAcercaDesarrollador"/>
                        <MenuItem text="Repositorio GitHub" onAction="#handleRepositorioGitHub"/>
                    </Menu>
                </MenuBar>

                <!-- 2. BARRA DE HERRAMIENTAS (ToolBar): Botones expuestos para ejecución inmediata en un solo clic -->
                <ToolBar>
                    <items>
                        <!-- Bloque de Inicio -->
                        <Button text="📈 Cuadro de Mando" onAction="#handleCuadroMando"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Bloque de Convocatorias y Gestión Operativa de Vacantes -->
                        <Button text="➕ Crear Oferta" onAction="#handleCrearOferta"/>
                        <Button text="📂 Historial de Ofertas" onAction="#handleHistorialOfertas"/>
                        <Button text="👥 Gestión de Candidatos" onAction="#handleGestionCandidatos"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Bloque de Alianza Legal -->
                        <Button text="📜 Tramitar Convenio" onAction="#handleTramitarConvenio"/>

                        <!-- Región de expansión invisible que empuja las opciones de sesión hacia el extremo derecho -->
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Botón directo de salida rápida con estilo de peligro unificado -->
                        <Button text="🚪 Cerrar Sesión" onAction="#handleCerrarSesion" styleClass="button-danger"/>
                    </items>
                </ToolBar>
            </children>
        </VBox>
    </top>
    <center>
        <!-- Panel de Visualización Central Único encargado de reemplazar el contenido -->
        <StackPane fx:id="panelCentralDisp" style="-fx-padding: 20;"/>
    </center>
</BorderPane>