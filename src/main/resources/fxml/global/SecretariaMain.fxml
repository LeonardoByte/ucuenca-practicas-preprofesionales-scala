<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.gestion.controllers.SecretariaMainController" prefWidth="1280.0" prefHeight="850.0" stylesheets="@../../css/styles.css">
    <top>
        <!-- Contenedor vertical para organizar simétricamente la MenuBar y la ToolBar de Secretaría -->
        <VBox>
            <children>
                <!-- 1. BARRA DE MENÚS (MenuBar): Tu árbol de navegación desplegable original -->
                <MenuBar>
                    <Menu text="Inicio">
                        <MenuItem text="Resumen Operativo" onAction="#handleResumenOperativo"/>
                    </Menu>
                    <Menu text="Cartas Compromiso">
                        <MenuItem text="Validar Entrega" onAction="#handleValidarEntrega"/>
                    </Menu>
                    <Menu text="Convenios">
                        <MenuItem text="Solicitudes de Convenio" onAction="#handleSolicitudesConvenio"/>
                    </Menu>
                    <Menu text="Sesión">
                        <MenuItem text="Cerrar Sesión" onAction="#handleCerrarSesion"/>
                        <MenuItem text="Salir del Sistema" onAction="#handleSalirSistema"/>
                    </Menu>
                    <Menu text="Ayuda">
                        <MenuItem text="Acerca del programa" onAction="#handleAcercaPrograma"/>
                        <MenuItem text="Acerca del desarrollador" onAction="#handleAcercaDesarrollador"/>
                        <MenuItem text="Repositorio GitHub" onAction="#handleRepositorioGitHub"/>
                    </Menu>
                </MenuBar>

                <!-- 2. BARRA DE HERRAMIENTAS (ToolBar): Botones expuestos para la ejecución de acciones rápidas -->
                <ToolBar>
                    <items>
                        <!-- Bloque de Inicio y Control Operativo -->
                        <Button text="📋 Resumen Operativo" onAction="#handleResumenOperativo"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Bloque de Gestión de Documentación Física y Convenios -->
                        <Button text="📜 Validar Entrega" onAction="#handleValidarEntrega"/>
                        <Button text="🤝 Solicitudes de Convenio" onAction="#handleSolicitudesConvenio"/>

                        <!-- Región invisible de expansión que empuja el botón de salida al extremo derecho -->
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Botón directo de salida con el estilo de peligro unificado -->
                        <Button text="🚪 Cerrar Sesión" onAction="#handleCerrarSesion" styleClass="button-danger"/>
                    </items>
                </ToolBar>
            </children>
        </VBox>
    </top>
    <center>
        <!-- Panel de Visualización Central Único encargado de reemplazar el contenido -->
        <StackPane fx:id="panelCentralDisp" style="-fx-padding: 20;"/>
    </center>
</BorderPane>