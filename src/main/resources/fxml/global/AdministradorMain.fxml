<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" prefWidth="1280.0" prefHeight="850.0" stylesheets="@../../css/styles.css" fx:controller="com.ucuenca.gestion.controllers.AdministradorMainController">
    <top>
        <!-- El VBox nos permite agrupar y apilar de forma vertical la MenuBar y la ToolBar -->
        <VBox>
            <children>
                <!-- 1. BARRA DE MENÚS (MenuBar): Tu navegación original mediante listas desplegables -->
                <MenuBar>
                    <Menu text="Inicio">
                        <MenuItem text="Estado del Sistema" onAction="#handleEstadoSistema"/>
                    </Menu>
                    <Menu text="Usuarios">
                        <MenuItem text="Registrar Usuario" onAction="#handleRegistrarUsuario"/>
                        <MenuItem text="Directorio General" onAction="#handleDirectorioGeneral"/>
                    </Menu>
                    <Menu text="Auditoría Global">
                        <MenuItem text="Trazabilidad de Prácticas" onAction="#handleTrazabilidad"/>
                    </Menu>
                    <Menu text="Reportes">
                        <MenuItem text="Generar Estadísticas" onAction="#handleGenerarEstadisticas"/>
                    </Menu>
                    <Menu text="Sesión">
                        <MenuItem text="Cerrar Sesión" onAction="#handleCerrarSesion"/>
                        <MenuItem text="Salir del Sistema" onAction="#handleSalirSistema"/>
                    </Menu>
                    <Menu text="Ayuda">
                        <MenuItem text="Acerca del programa" onAction="#handleAcercaPrograma"/>
                        <MenuItem text="Acerca del desarrollador" onAction="#handleAcercaDesarrollador"/>
                        <MenuItem text="Repositorio GitHub" onAction="#handleRepositorioGitHub"/>
                    </Menu>
                </MenuBar>

                <!-- 2. BARRA DE HERRAMIENTAS (ToolBar): Botones de un solo clic que disparan los mismos métodos del controlador -->
                <ToolBar>
                    <items>
                        <!-- Botón directo al dashboard operativo -->
                        <Button text="🏠 Estado Sistema" onAction="#handleEstadoSistema"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Accesos rápidos al módulo de gestión de usuarios -->
                        <Button text="➕ Registrar Usuario" onAction="#handleRegistrarUsuario"/>
                        <Button text="📋 Directorio General" onAction="#handleDirectorioGeneral"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Accesos rápidos a las herramientas de control y reportería -->
                        <Button text="🔍 Auditar Trazabilidad" onAction="#handleTrazabilidad"/>
                        <Button text="📊 Generar Estadísticas" onAction="#handleGenerarEstadisticas"/>

                        <!-- Este Region actúa como expansor invisible para empujar el botón de salida al extremo derecho -->
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Acción de salida rápida con tu estilo de botón de peligro -->
                        <Button text="🚪 Cerrar Sesión" onAction="#handleCerrarSesion" styleClass="button-danger"/>
                    </items>
                </ToolBar>
            </children>
        </VBox>
    </top>
    <center>
        <!-- Panel de Visualización Central Único encargado de reemplazar el contenido -->
        <StackPane fx:id="panelCentralDisp" style="-fx-padding: 20;"/>
    </center>
</BorderPane>