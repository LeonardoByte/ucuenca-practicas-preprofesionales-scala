<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" prefWidth="1280.0" prefHeight="850.0" stylesheets="@../../css/styles.css" fx:controller="com.ucuenca.gestion.controllers.EstudianteMainController">
    <top>
        <!-- Contenedor vertical para organizar simétricamente la MenuBar y la ToolBar del Estudiante -->
        <VBox>
            <children>
                <!-- 1. BARRA DE MENÚS (MenuBar): Tu árbol de navegación desplegable original -->
                <MenuBar>
                    <Menu text="Inicio">
                        <MenuItem text="Mi Perfil" onAction="#handleMiPerfil"/>
                    </Menu>
                    <Menu text="Bolsa de Empleo">
                        <MenuItem text="Buscar Vacantes" onAction="#handleBuscarVacantes"/>
                    </Menu>
                    <Menu text="Empresa Propia">
                        <MenuItem text="Registrar Solicitud" onAction="#handleRegistrarSolicitud"/>
                    </Menu>
                    <Menu text="Trámites">
                        <MenuItem text="Historial de Postulaciones" onAction="#handleHistorialPostulaciones"/>
                    </Menu>
                    <Menu text="Mi Práctica">
                        <MenuItem text="Información General" onAction="#handleInfoGeneral"/>
                        <MenuItem text="Propuesta de Actividades" onAction="#handlePropuestaActividades"/>
                        <MenuItem text="Formulario 1" onAction="#handleFormulario1"/>
                    </Menu>
                    <Menu text="Sesión">
                        <MenuItem text="Cerrar Sesión" onAction="#handleCerrarSesion"/>
                        <MenuItem text="Salir del Sistema" onAction="#handleSalirSistema"/>
                    </Menu>
                    <Menu text="Ayuda">
                        <MenuItem text="Acerca del programa" onAction="#handleAcercaPrograma"/>
                        <MenuItem text="Acerca del desarrollador" onAction="#handleAcercaDesarrollador"/>
                        <MenuItem text="Repositorio GitHub" onAction="#handleRepositorioGitHub"/>
                    </Menu>
                </MenuBar>

                <!-- 2. BARRA DE HERRAMIENTAS (ToolBar): Botones expuestos para la ejecución de acciones rápidas -->
                <ToolBar>
                    <items>
                        <!-- Bloque de Inicio y Perfil Técnico -->
                        <Button text="👤 Mi Perfil" onAction="#handleMiPerfil"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Bloque de Bolsa de Empleo y Postulaciones -->
                        <Button text="💼 Buscar Vacantes" onAction="#handleBuscarVacantes"/>
                        <Button text="🏢 Registrar Solicitud" onAction="#handleRegistrarSolicitud"/>
                        <Button text="📂 Historial Trámites" onAction="#handleHistorialPostulaciones"/>

                        <Separator orientation="VERTICAL"/>

                        <!-- Bloque de Gestión de la Práctica Activa (Convergencia) -->
                        <Button text="🛈 Información General" onAction="#handleInfoGeneral"/>
                        <Button text="📝 Propuesta de Actividades" onAction="#handlePropuestaActividades"/>
                        <Button text="📜 Formulario 1" onAction="#handleFormulario1"/>

                        <!-- Región invisible de expansión que empuja el botón de salida al extremo derecho -->
                        <Region HBox.hgrow="ALWAYS" />

                        <!-- Botón directo de salida con el estilo de peligro unificado -->
                        <Button text="🚪 Cerrar Sesión" onAction="#handleCerrarSesion" styleClass="button-danger"/>
                    </items>
                </ToolBar>
            </children>
        </VBox>
    </top>
    <center>
        <!-- Panel de Visualización Central Único encargado de reemplazar el contenido -->
        <StackPane fx:id="panelCentralDisp" style="-fx-padding: 20;"/>
    </center>
</BorderPane>