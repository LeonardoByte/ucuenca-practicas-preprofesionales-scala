<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
style="-fx-padding: 15;"
alignment="TOP_CENTER">

    <VBox spacing="20" maxWidth="1260.0" VBox.vgrow="ALWAYS" alignment="TOP_LEFT">
        <children>

            <Label text="Panel de Tutela Técnica - Mis Alumnos Asignados" style="-fx-font-size: 16pt; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
            <Separator/>

            <FlowPane hgap="20" vgap="20" prefWidth="1260">
                <children>
                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #2563eb; -fx-border-left-width: 5px;">
                        <Label text="Fase de Inicio (Formulario 1)" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label text="2 Alumnos" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                        <Label text="Estructurando cronograma y plan de actividades" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #f59e0b; -fx-border-left-width: 5px;">
                        <Label text="Fase de Desarrollo" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label text="5 Alumnos" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                        <Label text="Ejecutando horas y tareas en el espacio laboral" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #10b981; -fx-border-left-width: 5px;">
                        <Label text="Peticiones de Cierre Recibidas" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label text="1 Alumno" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                        <Label text="Horas completadas en espera del Formulario 2" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #6366f1; -fx-border-left-width: 5px;">
                        <Label text="Actividades Planificadas" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label text="3 Tareas" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #6366f1;"/>
                        <Label text="Propuestas del cronograma enviadas a revisión" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>
                </children>
            </FlowPane>

            <Separator style="-fx-padding: 10 0;"/>

            <Label text="Nómina de Estudiantes bajo Supervisión Operativa" style="-fx-font-size: 12pt; -fx-font-weight: bold; -fx-text-fill: #475569;"/>

            <TableView fx:id="tblAlumnosAsignados" prefHeight="350" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn prefWidth="250" text="Nombre Completo del Alumno" />
                    <TableColumn prefWidth="200" text="Carrera Universitaria" />
                    <TableColumn prefWidth="120" text="Ciclo Actual" />
                    <TableColumn prefWidth="180" text="Etapa Actual del Proceso" />
                    <TableColumn prefWidth="150" text="Petición de Cierre (F2)" />
                </columns>
            </TableView>

        </children>
    </VBox>
</VBox>