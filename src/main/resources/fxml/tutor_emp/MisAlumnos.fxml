<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.gestion.controllers.MisAlumnosController" style="-fx-padding: 15;" alignment="TOP_CENTER">
    <VBox spacing="20" maxWidth="1260.0" VBox.vgrow="ALWAYS" alignment="TOP_LEFT">
        <children>
            <!-- Fila Superior: Títulos Base + Tarjeta de Identidad Aplanada Horizontalmente (Ultra Compacta) -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <children>
                    <VBox spacing="0">
                        <children>
                            <Label text="Panel de Tutela Técnica" style="-fx-font-size: 14pt; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                            <Label text="Mis Alumnos Asignados" style="-fx-font-size: 9.5pt; -fx-text-fill: #64748b;"/>
                        </children>
                    </VBox>

                    <!-- Región expansora invisible para empujar el badge de identidad al extremo derecho -->
                    <Region HBox.hgrow="ALWAYS" />

                    <!-- Badge de Perfil Aplanado: Todo en una sola línea horizontal para minimizar el alto -->
                    <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #f1f5f9; -fx-padding: 4 10; -fx-background-radius: 4px; -fx-border-color: #cbd5e1; -fx-border-radius: 4px;">
                        <children>
                            <Label text="👤" style="-fx-font-size: 10pt;"/>
                            <Label fx:id="lblUsuarioNombreDashboard" text="[Nombre Completo del Tutor]" style="-fx-text-fill: #0f172a; -fx-font-weight: bold; -fx-font-size: 9.5pt;"/>

                            <Separator orientation="VERTICAL" prefHeight="14.0"/>

                            <Label text="Rol:" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 9pt;"/>
                            <Label fx:id="lblUsuarioRolDashboard" text="Tutor Empresarial" style="-fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-font-size: 9pt;"/>
                        </children>
                    </HBox>
                </children>
            </HBox>
            <Separator/>

            <FlowPane hgap="20" vgap="20" prefWidth="1260">
                <children>
                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #2563eb; -fx-border-left-width: 5px;">
                        <Label text="Fase de Inicio (Formulario 1)" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="lblAlumnosInicio" text="0 Alumnos" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #2563eb;"/>
                        <Label text="Estructurando cronograma y plan de actividades" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #f59e0b; -fx-border-left-width: 5px;">
                        <Label text="Fase de Desarrollo" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="lblAlumnosDesarrollo" text="0 Alumnos" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                        <Label text="Ejecutando horas y tareas en el espacio laboral" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #10b981; -fx-border-left-width: 5px;">
                        <Label text="Peticiones de Cierre Recibidas" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="lblAlumnosCierre" text="0 Alumnos" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                        <Label text="Horas completadas en espera del Formulario 2" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>

                    <VBox styleClass="card-dashboard" prefWidth="285" spacing="10" style="-fx-border-left-color: #6366f1; -fx-border-left-width: 5px;">
                        <Label text="Actividades Planificadas" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                        <Label fx:id="lblTareasPlanificadas" text="0 Tareas" style="-fx-font-size: 22pt; -fx-font-weight: bold; -fx-text-fill: #6366f1;"/>
                        <Label text="Propuestas del cronograma enviadas a revisión" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
                    </VBox>
                </children>
            </FlowPane>

            <Separator style="-fx-padding: 10 0;"/>

            <Label text="Nómina de Estudiantes bajo Supervisión Operativa" style="-fx-font-size: 12pt; -fx-font-weight: bold; -fx-text-fill: #475569;"/>

            <TableView fx:id="tblAlumnosAsignados" prefHeight="350" VBox.vgrow="ALWAYS">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colEstudiante" prefWidth="250" text="Nombre Completo del Alumno" />
                    <TableColumn fx:id="colCarrera" prefWidth="200" text="Carrera Universitaria" />
                    <TableColumn fx:id="colCiclo" prefWidth="120" text="Ciclo Actual" />
                    <TableColumn fx:id="colEtapa" prefWidth="180" text="Etapa Actual del Proceso" />
                    <TableColumn fx:id="colCierre" prefWidth="150" text="Petición de Cierre (F2)" />
                </columns>
            </TableView>
        </children>
    </VBox>
</VBox>