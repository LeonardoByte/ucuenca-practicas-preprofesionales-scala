<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    <Label style="-fx-font-size: 14pt; -fx-font-weight: bold;" text="Base de Datos Temática - Directorio General de Cuentas" />
    
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="card-dashboard">
        <Label style="-fx-font-weight: bold;" text="Filtros de Búsqueda Rápida Múltiple:" />
        <TextField prefHeight="26.0" prefWidth="266.0" promptText="Filtrar por Nombre, ID o Correo electrónico..." />
        <ComboBox promptText="Filtrar por Rol..." />
        <ComboBox promptText="Estado Cuenta..." />
    </HBox>
    
    <TableView fx:id="tblDirectorioGeneral" prefHeight="350" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn prefWidth="250" text="Nombres y Apellidos" />
            <TableColumn prefWidth="150" text="Identificación" />
            <TableColumn prefWidth="150" text="Rol Asignado" />
            <TableColumn prefWidth="200" text="Correo" />
            <TableColumn prefWidth="200" text="Estado Cuenta" /> <!-- (Activa / Suspendida) -->
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button styleClass="button-primary" text="Modificar Datos de Perfil" />
        <Button styleClass="button-danger" text="Cambiar Estado de Cuenta (Activa / Suspendida)" />
    </HBox>
</VBox>
