<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.gestion.controllers.DirectorioGeneralController" style="-fx-padding: 10;">
    <Label style="-fx-font-size: 14pt; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Base de Datos Temática - Directorio General de Cuentas" />
    
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="card-dashboard">
        <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
        <Label style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;" text="Filtros de Búsqueda Rápida Múltiple:" />
        <TextField fx:id="txtBuscar" onKeyReleased="#handleFiltroCambio" prefHeight="26.0" prefWidth="266.0" promptText="Filtrar por Nombre, ID o Correo..." />
        <ComboBox fx:id="cmbRol" onAction="#handleFiltroCambio" promptText="Filtrar por Rol..." prefWidth="180"/>
        <ComboBox fx:id="cmbEstado" onAction="#handleFiltroCambio" promptText="Estado Cuenta..." prefWidth="150"/>
    </HBox>
    
    <TableView fx:id="tblDirectorioGeneral" prefHeight="300" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colNombres" prefWidth="250" text="Nombres y Apellidos" />
            <TableColumn fx:id="colIdentificacion" prefWidth="150" text="Identificación" />
            <TableColumn fx:id="colRol" prefWidth="150" text="Rol Asignado" />
            <TableColumn fx:id="colCorreo" prefWidth="200" text="Correo" />
            <TableColumn fx:id="colEstado" prefWidth="150" text="Estado Cuenta" />
        </columns>
    </TableView>

    <Label fx:id="lblEstado" text="" visible="false" style="-fx-font-weight: bold; -fx-font-size: 11pt;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnModificar" onAction="#handleModificar" styleClass="button-primary" text="Modificar Datos de Perfil" />
        <Button fx:id="btnCambiarEstado" onAction="#handleCambiarEstado" styleClass="button-danger" text="Cambiar Estado de Cuenta (Activa / Suspendida)" />
    </HBox>

    <VBox fx:id="paneEdicion" spacing="12" styleClass="card-tech" visible="false">
        <Label text="Modificar Datos de Contacto del Operador" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
        <GridPane hgap="15" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="150" prefWidth="150"/>
                <ColumnConstraints minWidth="350" prefWidth="450"/>
            </columnConstraints>
            <children>
                <Label text="Nombres Completos:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtEditNombres" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Correo Electrónico:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtEditCorreo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button onAction="#handleCancelar" text="Cancelar" styleClass="button-timeline"/>
            <Button onAction="#handleGuardar" text="Guardar Cambios" styleClass="button-primary"/>
        </HBox>
    </VBox>
</VBox>
