<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucuenca.gestion.controllers.TrazabilidadController" style="-fx-padding: 15;">
    <Label text="Inspección de Trazabilidad y Auditoría Omnipotente de Prácticas" style="-fx-font-size: 16pt; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
    <Separator/>
    
    <!-- 1. MECANISMO DE BÚSQUEDA Y SELECCIÓN INTERMEDIA -->
    <VBox spacing="10" styleClass="card-operational" style="-fx-background-color: #f8fafc; -fx-padding: 12; -fx-border-radius: 4; -fx-border-color: #e2e8f0;">
        <Label text="Buscador por Criterio de Entidad Jurídica o Estudiante" style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="txtBuscarCriterio" promptText="Ingrese nombre de la empresa, cédula o del alumno..." prefWidth="400"/>
            <Button fx:id="btnBuscar" text="Buscar Prácticas Asociadas" onAction="#handleBuscar" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
        <Label text="Lista Intermedia de Prácticas Halladas (Seleccione una para auditar individualmente):" style="-fx-font-size: 10pt; -fx-font-weight: bold; -fx-padding: 5 0 0 0;"/>
        <TableView fx:id="tblListaIntermediaPracticas" prefHeight="160">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colCodigo" text="Código Práctica" prefWidth="120"/>
                <TableColumn fx:id="colEstudiante" text="Estudiante" prefWidth="220"/>
                <TableColumn fx:id="colEmpresa" text="Empresa Externa" prefWidth="220"/>
                <TableColumn fx:id="colFecha" text="Fecha Registro" prefWidth="130"/>
                <TableColumn fx:id="colEstado" text="Estado del Proceso" prefWidth="150"/>
            </columns>
        </TableView>
    </VBox>
    
    <!-- 2. COMPONENTE DE LÍNEA DE VIDA CRONOLÓGICA COMPLETA -->
    <Label text="Línea de Vida Cronológica del Proceso Auditado" style="-fx-font-size: 12pt; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
    
    <ScrollPane fitToWidth="true" prefHeight="380" style="-fx-background-color: transparent;">
        <VBox spacing="15" style="-fx-padding: 10; -fx-background-color: #ffffff; -fx-border-color: #cbd5e1; -fx-border-radius: 6;">
            <children>
                <Label text="* Nota: Refleja el avance secuencial de la práctica (incluso si se encuentra en desarrollo)" style="-fx-font-style: italic; -fx-text-fill: #64748b; -fx-font-size: 9.5pt;"/>
                
                <!-- Contenedor dinámico de línea de vida -->
                <VBox fx:id="vboxTimeline" spacing="12"/>
                
                <!-- 3. CUADRO DE LECTURA CON OBSERVACIONES DE RECHAZO DE LA FASE -->
                <VBox spacing="5" styleClass="card-tech" style="-fx-border-left-color: #ef4444; -fx-padding: 10; -fx-background-color: #fef2f2; -fx-border-radius: 4;">
                    <Label text="Historial de Observaciones de Rechazo y Retroalimentación" style="-fx-font-weight: bold; -fx-text-fill: #b91c1c;"/>
                    <TextArea fx:id="txtAreaLecturaRetroalimentacion" prefHeight="100" editable="false" wrapText="true" style="-fx-font-family: 'Consolas'; -fx-font-size: 10pt;"/>
                </VBox>
            </children>
        </VBox>
    </ScrollPane>
</VBox>
