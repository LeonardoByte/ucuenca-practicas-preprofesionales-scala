<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" style="-fx-padding: 15;">
    <Label text="Cuadro de Mando - Resumen Operativo de Secretaría" style="-fx-font-size: 16pt; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
    <Separator/>

    <Label text="Visualización de la Carga Documental Pendiente de Trámite Físico" style="-fx-font-size: 12pt; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
    <FlowPane hgap="20" vgap="20" prefWidth="800">
        <children>
            <!-- Tarjeta 1: Cartas Compromiso Pendientes -->
            <VBox styleClass="card-dashboard" prefWidth="340" spacing="10" style="-fx-border-left-color: #ea580c; -fx-border-left-width: 5px;">
                <Label text="Cartas Compromiso por Firmar" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                <Label text="15 Carpetas" style="-fx-font-size: 24pt; -fx-font-weight: bold; -fx-text-fill: #ea580c;"/>
                <Label text="Copias físicas en espera de validación de entrega" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
            </VBox>

            <!-- Tarjeta 2: Solicitudes de Convenio -->
            <VBox styleClass="card-dashboard" prefWidth="340" spacing="10" style="-fx-border-left-color: #1e3a8a; -fx-border-left-width: 5px;">
                <Label text="Solicitudes de Convenio Jurídico" style="-fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                <Label text="2 Peticiones" style="-fx-font-size: 24pt; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;"/>
                <Label text="Nuevos convenios de empresas por procesar" style="-fx-font-size: 9pt; -fx-text-fill: #94a3b8;"/>
            </VBox>
        </children>
    </FlowPane>
</VBox>
